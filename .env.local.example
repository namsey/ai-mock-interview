# ==========================================
# API Keys (Required)
# ==========================================

# Get your OpenAI key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-key-here

# Get your Anthropic key from https://console.anthropic.com
# (Only needed if you enable Anthropic in config.json)
ANTHROPIC_API_KEY=sk-ant-api03-your-anthropic-key-here

# ==========================================
# Configuration
# ==========================================
# All AI configuration (models, providers, preferences) is now managed in config.json
# To change models or enable/disable providers, edit config.json instead of this file
# This file should only contain your API keys for security
