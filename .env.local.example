# Get your Anthropic key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your-anthropic-key-here

# Get your OpenAI key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-key-here

# Optional: override the default model choices
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# OPENAI_MODEL=gpt-4o-mini
# AI_PROVIDER=openai

# Note: You can configure one or both API keys.
# If both are configured, the system will automatically fall back to the available key
# when one provider's quota is exhausted or rate-limited.
